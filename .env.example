# Variáveis de ambiente para desenvolvimento e produção

# PostgreSQL Connection String
# No Render, você recebe as credenciais automaticamente
ConnectionStrings__ConexaoPadrao=Host=seu_host;Port=5432;Database=sua_db;Username=seu_user;Password=sua_senha;SSL Mode=Require;Trust Server Certificate=true

# URLs dos serviços
EstoqueServiceUrl=https://seu-servico-estoque.onrender.com
FaturamentoServiceUrl=https://seu-servico-faturamento.onrender.com

# Ambiente
ASPNETCORE_ENVIRONMENT=Production

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
